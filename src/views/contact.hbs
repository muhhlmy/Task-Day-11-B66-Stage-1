<section
  id="contact"
  class="w-full grow text-gray-800 flex flex-col items-center justify-center py-20 px-4 min-h-[80vh]"
>
  <div class="flex flex-col items-center justify-center mb-10 mt-6">
    <h1 class="font-extrabold text-center text-4xl text-gray-900">
      GET IN TOUCH
    </h1>
    <div class="w-16 h-1.5 bg-gray-900 rounded-full mt-6"></div>
  </div>

  <form
    class="w-full max-w-lg bg-white p-10 rounded-3xl shadow-xl shadow-gray-200/50 border border-gray-100 flex flex-col gap-6"
  >
    <!-- Name -->
    <div class="flex flex-col gap-2">
      <label for="inputName" class="font-bold text-sm text-gray-700">
        Name
      </label>
      <input
        type="text"
        class="w-full px-5 py-3.5 bg-gray-50 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all shadow-sm"
        id="inputName"
        placeholder="e.g. John Doe"
        required
      />
    </div>

    <!-- Email -->
    <div class="flex flex-col gap-2">
      <label for="inputEmail" class="font-bold text-sm text-gray-700">
        Email Address
      </label>
      <input
        type="email"
        class="w-full px-5 py-3.5 bg-gray-50 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all shadow-sm"
        id="inputEmail"
        placeholder="e.g. john@example.com"
        required
      />
    </div>

    <!-- Message -->
    <div class="flex flex-col gap-2">
      <label for="inputMessage" class="font-bold text-sm text-gray-700">
        Message
      </label>
      <textarea
        class="w-full px-5 py-3.5 bg-gray-50 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all shadow-sm resize-none"
        id="inputMessage"
        rows="5"
        placeholder="Write your message here..."
        required
      ></textarea>
    </div>

    <!-- Buttons -->
    <div class="flex gap-4 mt-6">
      <a
        href="/"
        class="w-1/3 flex justify-center items-center py-3.5 px-6 border-2 border-gray-200 rounded-full hover:bg-gray-50 hover:border-gray-300 text-gray-700 font-bold transition-all"
      >
        Back
      </a>
      <button
        type="submit"
        class="w-2/3 py-3.5 px-6 bg-gray-900 rounded-full text-white hover:-translate-y-1 hover:shadow-xl hover:shadow-gray-900/20 duration-300 transition-all font-bold cursor-pointer"
      >
        Send Message
      </button>
    </div>
  </form>
</section>