<section
  id="form"
  class="w-full text-gray-800 flex flex-col justify-center items-center py-16 px-4 gap-8"
>
  <div class="flex flex-col items-center justify-center mb-4 mt-6">
    <h1 class="font-extrabold text-center text-4xl text-gray-900">
      ADD MY PROJECT
    </h1>
    <div class="w-16 h-1.5 bg-gray-900 rounded-full mt-6"></div>
  </div>

  <form
    action="/project"
    method="POST"
    id="projectForm"
    class="bg-white border border-gray-100 shadow-xl shadow-gray-200/50 rounded-3xl p-8 sm:p-10 w-full md:w-8/12 lg:w-6/12 xl:w-5/12 transition-all"
  >
    <!-- Project Name -->
    <div class="mb-5">
      <label
        for="projectName"
        class="block font-bold mb-2 text-sm text-gray-700"
      >
        Project Name
      </label>
      <input
        type="text"
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all"
        name="projectName"
        id="projectName"
        placeholder="e.g. Personal Website"
        required
      />
    </div>

    <!-- Dates -->
    <div class="flex flex-col md:flex-row gap-5 mb-5">
      <div class="w-full md:w-1/2">
        <label
          for="projectStartDate"
          class="block font-bold mb-2 text-sm text-gray-700"
        >
          Start Date
        </label>
        <input
          type="date"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all text-gray-600 hover:cursor-pointer"
          name="projectStartDate"
          id="projectStartDate"
          required
        />
      </div>
      <div class="w-full md:w-1/2">
        <label
          for="projectEndDate"
          class="block font-bold mb-2 text-sm text-gray-700"
        >
          End Date
        </label>
        <input
          type="date"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all text-gray-600 hover:cursor-pointer"
          name="projectEndDate"
          id="projectEndDate"
          required
        />
      </div>
    </div>

    <!-- Description -->
    <div class="mb-5">
      <label
        for="projectDescription"
        class="block font-bold mb-2 text-sm text-gray-700"
      >
        Description
      </label>
      <textarea
        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl shadow-sm resize-none focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all"
        rows="4"
        name="projectDescription"
        id="projectDescription"
        placeholder="Write a short description..."
        required
      ></textarea>
    </div>

    <!-- Technologies -->
    <div class="mb-5">
      <label class="block font-bold mb-3 text-sm text-gray-700">
        Technologies
      </label>
      <div class="grid grid-cols-2 gap-y-3 gap-x-4">
        <div>
          <div class="flex items-center gap-3">
            <input
            name="isNodeJs"
              class="w-4.5 h-4.5 text-gray-900 bg-gray-50 border-gray-300 rounded focus:ring-gray-900 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="nodejs"
              value="true"
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="nodejs"
            >
              Node JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <input
             name="isNextJs"
              class="w-4.5 h-4.5 text-gray-900 bg-gray-50 border-gray-300 rounded focus:ring-gray-900 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="nextjs"
              value="true"
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="nextjs"
            >
              Next JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <input
              name="isReactJs"
              class="w-4.5 h-4.5 text-gray-900 bg-gray-50 border-gray-300 rounded focus:ring-gray-900 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="reactjs"
              value="true"
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="reactjs"
            >
              React JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <input
            name="isTypescript"
              class="w-4.5 h-4.5 text-gray-900 bg-gray-50 border-gray-300 rounded focus:ring-gray-900 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="typescript"
              value="true"
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="typescript"
            >
              TypeScript
            </label>
          </div>
        </div>
      </div>
    </div>

    <!-- Upload Image -->
    {{!-- <div class="mb-8">
      <label
        for="projectImage"
        class="block font-bold mb-2 text-sm text-gray-700"
      >
        Upload Image
      </label>
      <div
        class="relative rounded-xl overflow-hidden border border-gray-200 bg-gray-50 hover:bg-gray-100 transition-colors"
      >
        <input
          type="file"
          class="w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-4 file:border-0 file:text-sm file:font-bold file:bg-gray-200 file:text-gray-700 hover:file:bg-gray-300 cursor-pointer"
          name="projectImage"
          id="projectImage"
        />
      </div>
      <p class="text-gray-400 text-xs mt-2 font-medium">
        * Upload an image in JPG or PNG format
      </p>
    </div> --}}

    <!-- Buttons -->
    <div class="flex justify-end mt-2">
      <button
        type="submit"
        class="bg-gray-900 hover:bg-gray-800 text-white font-semibold rounded-full px-12 py-3.5 w-full md:w-auto shadow-md hover:shadow-xl hover:shadow-gray-900/20 hover:-translate-y-1 transition-all duration-300 cursor-pointer"
      >
        Submit Project
      </button>
    </div>
  </form>
</section>

<section id="projects" class="bg-white py-20 border-t border-gray-100">
  <div class="container mx-auto px-4 max-w-7xl">
    <!-- Section Title -->
    <div class="flex flex-col items-center justify-center mb-16">
      <h2 class="font-extrabold text-center text-4xl text-gray-900">
        MY PROJECTS
      </h2>
      <div class="w-16 h-1.5 bg-gray-900 rounded-full mt-6"></div>
    </div>
    <!-- Search Input -->
    <div class="flex justify-end mb-10 w-full md:w-1/2 lg:w-1/3 ml-auto">
      <div
        class="flex items-center border-b-2 border-gray-300 pb-2 w-full focus-within:border-gray-900 transition-colors"
      >
        <i
          class="fa-solid fa-magnifying-glass text-gray-400 focus-within:text-gray-900 mx-3"
        ></i>
        <input
          type="text"
          class="w-full bg-transparent border-none focus:outline-none text-gray-800 placeholder-gray-400 p-0 m-0 shadow-none text-base font-medium"
          id="searchProject"
          placeholder="Search projects..."
        />
      </div>
    </div>

    <div
      id="projectContainer"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"
    >
    {{#if projects}}
      {{#each projects}}
      <!-- Dynamic Project Card Item -->
      <div
        class="w-full duration-300 transition-all custom-card-native group"
      >
        <div
          class="flex flex-col h-full border border-gray-100 rounded-3xl p-5 bg-white shadow-lg shadow-gray-200/50 hover:shadow-2xl hover:shadow-gray-300/60 hover:-translate-y-2 transition-all duration-500 relative overflow-hidden"
        >
          <div
            class="custom-card-glow opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          ></div>

          <div
            class="w-full aspect-[4/3] overflow-hidden rounded-2xl bg-gray-100 mb-5 relative"
          >
            <img
              src="{{#if projectImage}}{{projectImage}}{{else}}https://placehold.co/600x400?text={{projectName}}{{/if}}"
              class="project-image w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              alt="Project Image"
            />
          </div>
          <div class="grow flex flex-col relative z-10">
            <h5
              class="project-name font-extrabold text-xl mb-1.5 text-gray-900"
            >{{projectName}}</h5>
            <p
              class="project-duration text-gray-400 text-xs font-semibold mb-4 uppercase tracking-wider"
            >Durasi: {{duration}}</p>
            <p
              class="project-description text-gray-600 mb-5 line-clamp-3 text-sm leading-relaxed"
            >{{projectDescription}}</p>
            <div
              class="project-techs mb-6 text-gray-700 flex items-center gap-3 text-lg"
            >
                {{#if isNodeJs}}
                 <i class="fa-brands fa-node-js"></i>
                {{/if}}
                {{#if isNextJs}}
                 <img src="https://img.icons8.com/?size=100&id=yUdJlcKanVbh&format=png&color=000000" alt="NextJS" width="19">
                {{/if}}
                {{#if isReactJs}}
                 <i class="fa-brands fa-react"></i>
                {{/if}}
                {{#if isTypescript}}
                 <img src="https://img.icons8.com/?size=100&id=cHBUT9SmrD2V&format=png&color=000000" alt="NextJS" width="19">
                {{/if}}
            </div>
            <div class="flex gap-2 w-full mt-auto pt-4 border-t border-gray-50">
              <a href="/project/detail/{{id}}"
                class="flex-1 flex items-center justify-center border border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white transition-all duration-300 py-2 rounded-full font-bold text-xs shadow-sm cursor-pointer"
              >
                View
              </a>
              <a href="/project/edit/{{id}}"
                class="flex-1 flex items-center justify-center bg-yellow-50 text-yellow-600 hover:bg-yellow-500 hover:text-white border border-transparent hover:border-yellow-600 transition-all duration-300 py-2 rounded-full font-bold text-xs cursor-pointer"
              >
                Edit
              </a>
              <form action="/project/delete/{{id}}" method="post" class="flex-1 flex h-full" onsubmit="return confirm('Apakah Anda yakin ingin menghapus project ini?');">
                <button
                  type="submit"
                  class="flex items-center justify-center w-full bg-red-50 text-red-600 hover:bg-red-600 hover:text-white border border-transparent hover:border-red-700 transition-all duration-300 py-2 rounded-full font-bold text-xs cursor-pointer"
                >
                  Delete
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
      {{else}}
      <h1 class="col-span-4 text-center text-gray-400">Tidak ada Project</h1>
      {{/if}}
    </div>
  </div>
</section>