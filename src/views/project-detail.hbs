<section class="bg-gray-50 py-16 min-h-[calc(100vh-80px)]">
  <div class="container mx-auto px-4 max-w-5xl">
    <!-- Breadcrumb -->
    <nav class="flex mb-8 text-sm font-medium text-gray-500">
      <a href="/projects" class="hover:text-gray-900 transition-colors">Projects</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 truncate">{{project.projectName}}</span>
    </nav>

    <!-- Content Wrapper -->
    <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/50 overflow-hidden border border-gray-100">
      <div class="p-8 md:p-12">
        <!-- Header -->
        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-8">{{project.projectName}}</h1>

        <div class="flex flex-col md:flex-row gap-10">
          <!-- Image Section -->
          <div class="w-full md:w-2/3">
            <div class="rounded-2xl overflow-hidden bg-gray-100 shadow-sm border border-gray-100">
              <img
                src="{{#if project.projectImage}}{{project.projectImage}}{{else}}https://placehold.co/1200x800?text={{project.projectName}}{{/if}}"
                alt="Project Image"
                class="w-full h-auto object-cover aspect-video"
              />
            </div>
          </div>

          <!-- Info Section -->
          <div class="w-full md:w-1/3 flex flex-col gap-8">
            <!-- Duration -->
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
                <i class="fa-regular fa-calendar text-gray-500"></i> Duration
              </h3>
              <ul class="space-y-2 text-gray-600 font-medium">
                <li class="flex items-center gap-2">
                  <span class="text-gray-800">{{project.projectStartDate}}</span> - <span class="text-gray-800">{{project.projectEndDate}}</span>
                </li>
                <li class="flex items-center gap-2 mt-1">
                  <span class="text-gray-500 font-bold"><i class="fa-regular fa-clock mr-1"></i> {{project.duration}}</span>
                </li>
              </ul>
            </div>

            <!-- Technologies -->
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-code text-gray-500"></i> Technologies
              </h3>
              <div class="flex flex-wrap gap-4 text-2xl text-gray-700">
                {{#if project.isNodeJs}}
                  <div class="flex flex-col items-center gap-1 group cursor-help">
                    <i class="fa-brands fa-node-js group-hover:text-green-600 transition-colors"></i>
                    <span class="text-xs font-semibold text-gray-400 group-hover:text-green-600">Node JS</span>
                  </div>
                {{/if}}
                {{#if project.isNextJs}}
                  <div class="flex flex-col items-center gap-1 group cursor-help">
                    <img src="https://img.icons8.com/?size=100&id=yUdJlcKanVbh&format=png&color=000000" alt="NextJS" width="24" class="opacity-80 group-hover:opacity-100 transition-opacity">
                    <span class="text-xs font-semibold text-gray-400 group-hover:text-gray-900">Next JS</span>
                  </div>
                {{/if}}
                {{#if project.isReactJs}}
                  <div class="flex flex-col items-center gap-1 group cursor-help">
                    <i class="fa-brands fa-react group-hover:text-blue-500 transition-colors"></i>
                    <span class="text-xs font-semibold text-gray-400 group-hover:text-blue-500">React JS</span>
                  </div>
                {{/if}}
                {{#if project.isTypescript}}
                  <div class="flex flex-col items-center gap-1 group cursor-help">
                    <img src="https://img.icons8.com/?size=100&id=cHBUT9SmrD2V&format=png&color=000000" alt="TypeScript" width="24" class="opacity-80 group-hover:opacity-100 transition-opacity">
                    <span class="text-xs font-semibold text-gray-400 group-hover:text-blue-600">TypeScript</span>
                  </div>
                {{/if}}
              </div>
            </div>
          </div>
        </div>

        <!-- Description Section -->
        <div class="mt-12 pt-10 border-t border-gray-100">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">About the project</h3>
          <p class="text-gray-600 leading-relaxed text-lg whitespace-pre-line text-justify">{{project.projectDescription}}</p>
        </div>
      </div>
    </div>
  </div>
</section>
