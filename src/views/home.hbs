<section
  id="homeSection"
  class="w-full grow text-gray-800 flex flex-col items-center justify-center py-12 md:py-20 gap-16 px-4"
>
  {{! Hero (Photo & Hero Content) }}
  <div
    class="container mx-auto max-w-6xl flex flex-col-reverse md:flex-row gap-12 lg:gap-20 items-center justify-between"
  >
    {{! Hero Content }}
    <div
      class="w-full md:w-3/5 flex flex-col gap-6 items-center md:items-start text-center md:text-left mt-4 md:mt-0"
    >
      <h6
        class="inline-block px-4 py-1.5 rounded-full bg-gray-200/50 text-gray-600 font-bold text-xs sm:text-sm tracking-widest uppercase border border-gray-300 backdrop-blur-sm shadow-sm"
      >
        Fullstack Developer
      </h6>
      <h2
        class="text-4xl sm:text-5xl lg:text-7xl font-extrabold leading-tight text-gray-900 tracking-tight"
      >
        Hi there!
        <br class="hidden md:block" />
        Nice to meet you.
      </h2>
      <p
        class="text-base sm:text-lg lg:text-xl text-gray-500 leading-relaxed max-w-2xl font-medium"
      >
        Crafting digital experiences where high-end editorial aesthetics meet
        robust architectural performance. I build scalable applications with a
        focus on restrained design and purposeful interaction.
      </p>

      {{! Buttons Container }}
      <div class="flex flex-col sm:flex-row gap-4 mt-6 w-full sm:w-auto">
        <a
          href="/contact"
          class="group flex justify-center items-center gap-2 py-3.5 px-8 bg-gray-900 rounded-full text-white hover:bg-gray-800 hover:-translate-y-1 hover:shadow-xl hover:shadow-gray-900/20 duration-300 transition-all font-semibold"
        >
          Contact Me
          <i
            class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"
          ></i>
        </a>
        <a
          href="https://drive.google.com/file/d/1oPvbJ0Uco0fnF1QJs1hy4bq7SaKO-Sc4/view"
          target="_blank"
          class="flex justify-center items-center gap-3 py-3.5 px-8 bg-white border border-gray-200 rounded-full hover:border-gray-300 hover:bg-gray-50 text-gray-800 hover:-translate-y-1 hover:shadow-lg duration-300 transition-all font-semibold"
        >
          Download CV
          <i class="fa-solid fa-download"></i>
        </a>
      </div>

      {{! Social }}
      <div class="flex justify-center md:justify-start items-center gap-4 mt-6">
        <span
          class="text-sm font-semibold text-gray-400 uppercase tracking-widest mr-2"
        >
          Connect
        </span>
        <a
          href="https://www.linkedin.com/in/muh-hlmy/"
          target="_blank"
          class="flex justify-center items-center h-12 w-12 bg-white rounded-full hover:-translate-y-1 duration-300 transition-all shadow-sm hover:shadow-md text-gray-600 hover:text-blue-600 border border-gray-100"
        >
          <i class="fa-brands fa-linkedin-in text-lg"></i>
        </a>
        <a
          href="https://www.instagram.com/muhhl.my/"
          target="_blank"
          class="flex justify-center items-center h-12 w-12 bg-white rounded-full hover:-translate-y-1 duration-300 transition-all shadow-sm hover:shadow-md text-gray-600 hover:text-pink-600 border border-gray-100"
        >
          <i class="fa-brands fa-instagram text-lg"></i>
        </a>
        <a
          href="https://github.com/muhhlmy/"
          target="_blank"
          class="flex justify-center items-center h-12 w-12 bg-white rounded-full hover:-translate-y-1 duration-300 transition-all shadow-sm hover:shadow-md text-gray-600 hover:text-gray-900 border border-gray-100"
        >
          <i class="fa-brands fa-github text-lg"></i>
        </a>
      </div>
    </div>

    {{! Photo }}
    <div class="w-full md:w-2/5 flex justify-center md:justify-end">
      <div class="relative w-72 sm:w-80 lg:w-96 group pb-4 lg:pb-0">
        <div
          class="absolute inset-0 bg-gradient-to-tr from-gray-200 to-gray-100 rounded-3xl transform rotate-3 group-hover:rotate-6 transition-transform duration-500 shadow-inner"
        ></div>
        <div
          class="relative bg-white p-3 rounded-3xl shadow-xl shadow-gray-200/50 hover:-translate-y-2 transition-all duration-500 border border-gray-100/50"
        >
          <div
            class="w-full aspect-[4/5] rounded-2xl overflow-hidden bg-gray-100"
          >
            <img
              src="/images/profile.png"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              alt="Muhammad Helmy"
            />
          </div>
          <div
            class="absolute bottom-8 left-6 right-6 bg-white/95 backdrop-blur-md p-4 rounded-xl border border-gray-100 shadow-xl text-center transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 z-10 hidden sm:block"
          >
            <h2 class="font-bold text-gray-900 text-lg">
              Muhammad Helmy
            </h2>
            <p class="text-sm text-gray-500 font-medium">
              Jakarta, Indonesia
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  {{! Tech Cards }}
  <div class="container mx-auto max-w-6xl w-full mt-12 mb-12">
    <div class="flex flex-col justify-center gap-8">
      <div class="flex flex-col items-center">
        <h2 class="font-extrabold text-3xl text-gray-900 text-center">
          My Tech Stack
        </h2>
        <div class="w-16 h-1.5 bg-gray-900 rounded-full mt-4"></div>
      </div>

      {{! Tech Container }}
      <div
        id="techCardContainer"
        class="flex flex-wrap justify-center gap-4 py-4"
      >
        {{! Tech Card }}
        {{#if techStack}}
          {{#each techStack}}
            <div
              class="group flex gap-3 items-center bg-gray-900 border border-gray-200 text-white text-lg font-bold py-3 px-6 rounded-2xl flex-shrink-0 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-gray-200/50 hover:bg-white hover:text-gray-900 hover:border-gray-200 duration-300 transition-all cursor-pointer"
            >
              <div
                class="text-2xl group-hover:scale-110 transition-transform duration-300"
              >
                {{{icon}}}
              </div>
              <p>
                {{techName}}
              </p>
            </div>
          {{/each}}
        {{/if}}
      </div>
    </div>
  </div>
</section>