<section
  id="form"
  class="w-full text-gray-800 flex flex-col justify-center items-center py-16 px-4 gap-8 min-h-[80vh]"
>
  <div class="flex flex-col items-center justify-center mb-4 mt-6">
    <h1 class="font-extrabold text-center text-4xl text-gray-900 uppercase">
      Edit Project
    </h1>
    <div class="w-16 h-1.5 bg-yellow-500 rounded-full mt-6"></div>
  </div>

  <form
    action="/project/update/{{project.id}}"
    method="POST"
    class="bg-white border border-gray-100 shadow-xl shadow-gray-200/50 rounded-3xl p-8 sm:p-10 w-full md:w-8/12 lg:w-6/12 xl:w-5/12 transition-all relative overflow-hidden"
  >
    <!-- Add a subtle color hint for edit mode -->
    <div class="absolute top-0 left-0 w-full h-2 bg-yellow-500"></div>

    <!-- Project Name -->
    <div class="mb-5 mt-2">
      <label
        for="projectName"
        class="block font-bold mb-2 text-sm text-gray-700"
      >
        Project Name
      </label>
      <input
        type="text"
        class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent transition-all"
        name="projectName"
        id="projectName"
        value="{{project.projectName}}"
        placeholder="e.g. Personal Website"
        required
      />
    </div>

    <!-- Dates -->
    <div class="flex flex-col md:flex-row gap-5 mb-5">
      <div class="w-full md:w-1/2">
        <label
          for="projectStartDate"
          class="block font-bold mb-2 text-sm text-gray-700"
        >
          Start Date
        </label>
        <input
          type="date"
          class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent transition-all text-gray-600 hover:cursor-pointer"
          name="projectStartDate"
          id="projectStartDate"
          value="{{project.projectStartDate}}"
        />
      </div>
      <div class="w-full md:w-1/2">
        <label
          for="projectEndDate"
          class="block font-bold mb-2 text-sm text-gray-700"
        >
          End Date
        </label>
        <input
          type="date"
          class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent transition-all text-gray-600 hover:cursor-pointer"
          name="projectEndDate"
          id="projectEndDate"
          value="{{project.projectEndDate}}"
        />
      </div>
    </div>

    <!-- Description -->
    <div class="mb-5">
      <label
        for="projectDescription"
        class="block font-bold mb-2 text-sm text-gray-700"
      >
        Description
      </label>
      <textarea
        class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-xl shadow-sm resize-none focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-transparent transition-all"
        rows="4"
        name="projectDescription"
        id="projectDescription"
        placeholder="Write a short description..."
        required
      >{{project.projectDescription}}</textarea>
    </div>

    <!-- Technologies -->
    <div class="mb-5">
      <label class="block font-bold mb-3 text-sm text-gray-700">
        Technologies
      </label>
      <div class="grid grid-cols-2 gap-y-3 gap-x-4">
        <div>
          <div class="flex items-center gap-3">
            <input
              class="w-4.5 h-4.5 text-yellow-600 bg-gray-50 border-gray-300 rounded focus:ring-yellow-500 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="nodejs"
              name="isNodeJs"
              value="true"
              {{#if project.isNodeJs}}checked{{/if}}
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="nodejs"
            >
              Node JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <input
              class="w-4.5 h-4.5 text-yellow-600 bg-gray-50 border-gray-300 rounded focus:ring-yellow-500 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="nextjs"
              name="isNextJs"
              value="true"
              {{#if project.isNextJs}}checked{{/if}}
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="nextjs"
            >
              Next JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <input
              class="w-4.5 h-4.5 text-yellow-600 bg-gray-50 border-gray-300 rounded focus:ring-yellow-500 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="reactjs"
              name="isReactJs"
              value="true"
              {{#if project.isReactJs}}checked{{/if}}
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="reactjs"
            >
              React JS
            </label>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <input
              class="w-4.5 h-4.5 text-yellow-600 bg-gray-50 border-gray-300 rounded focus:ring-yellow-500 focus:ring-2 cursor-pointer"
              type="checkbox"
              id="typescript"
              name="isTypescript"
              value="true"
              {{#if project.isTypescript}}checked{{/if}}
            />
            <label
              class="text-gray-700 font-medium cursor-pointer text-sm"
              for="typescript"
            >
              TypeScript
            </label>
          </div>
        </div>
      </div>
    </div>

    <!-- Upload Image -->
    {{!-- <div class="mb-8">
      <label
        for="projectImage"
        class="block font-bold mb-2 text-sm text-gray-700"
      >
        Update Image
        <span class="text-gray-400 font-normal text-xs ml-1">
          (Optional)
        </span>
      </label>
      <div
        class="relative rounded-xl overflow-hidden border border-gray-200 bg-gray-50 hover:bg-gray-100 transition-colors"
      >
        <input
          type="file"
          class="w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-4 file:border-0 file:text-sm file:font-bold file:bg-gray-200 file:text-gray-700 hover:file:bg-gray-300 cursor-pointer"
          name="projectImage"
          id="projectImage"
        />
      </div>
    </div> --}}

    <!-- Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 mt-6">
      <a
        href="/project"
        class="w-full sm:w-1/3 flex justify-center items-center py-3.5 px-6 border-2 border-gray-200 rounded-full hover:bg-gray-50 hover:border-gray-300 text-gray-700 font-bold transition-all text-center"
      >
        Cancel
      </a>
      <button
        type="submit"
        class="w-full sm:w-2/3 bg-yellow-500 hover:bg-yellow-600 text-white font-bold rounded-full px-8 py-3.5 shadow-md hover:shadow-xl hover:shadow-yellow-500/30 hover:-translate-y-1 transition-all duration-300 cursor-pointer"
      >
        Save Changes
      </button>
    </div>
  </form>
</section>